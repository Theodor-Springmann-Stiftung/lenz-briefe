    {
      "id": "letter-197-page-1-sidenote-1",
      "order": 1,
      "letter": "197",
      "page": "1",
      "pos": "top",
      "annotation": "Am oberen Rand",
      "html": "<aside class=\"sidenote\" id=\"letter-197-page-1-sidenote-1\" data-letter=\"197\" data-page=\"1\" data-pos=\"top\" data-annotation=\"Am oberen Rand\">\n   <div class=\"lb-line-block\" data-type=\"break\">\n    im Kriege können die Weiber auf und mitgehn, die Kinder den Eltern lassen\n</div>\n   <div class=\"lb-line-block\" data-type=\"break\">Soldatenweiber nähren sich mit ihrer Arbeit\n</div>\n   <div class=\"lb-line-block\" data-type=\"break\">Offiziers von ihren Männern trennen\n</div>\n   <div class=\"lb-line-block\" data-type=\"break\">Alle Anstalten wegen der Deserteurs fallen weg, Kinder zu hause\n</div>\n   <div class=\"lb-line-block\" data-type=\"break\"><span class=\"aq\">tout ou rien.</span> \n</div>\n   <div class=\"lb-line-block\" data-type=\"break\">Soldatenweiber machen die Marquatete\n</div>\n   <div class=\"lb-line-block\" data-type=\"break\">ich sah Weiber als Amazonen im Nothfall mit fechten und das stärkste <span class=\"aq\">corps de reserve</span> machen</div>\n</aside>"
    },
    {
      "id": "letter-197-page-1-sidenote-2",
      "order": 2,
      "letter": "197",
      "page": "1",
      "pos": "right",
      "annotation": "über dem zweiten Absatz",
      "html": "<aside class=\"sidenote\" id=\"letter-197-page-1-sidenote-2\" data-letter=\"197\" data-page=\"1\" data-pos=\"right\" data-annotation=\"über dem zweiten Absatz\">\n   <div class=\"lb-line-block\" data-type=\"break\">Daß alle Bürger itzt drauf können rechen daß die herzen ihrer Weiber an den Soldaten hängen die ledig sind.</div>\n</aside>"
    },
    {
      "id": "letter-197-page-1-sidenote-3",
      "order": 3,
      "letter": "197",
      "page": "1",
      "pos": "left",
      "annotation": "Am linken Rande, vertikal",
      "html": "<aside class=\"sidenote\" id=\"letter-197-page-1-sidenote-3\" data-letter=\"197\" data-page=\"1\" data-pos=\"left\" data-annotation=\"Am linken Rande, vertikal\">\n   <div class=\"lb-line-block\" data-type=\"break\" data-tab=\"1\">\nWieland ist ein herzguter Mann mit dem ich gleich zusammen geschmolzen bin. – – Auch sind sonst viel trefliche Menschen hier und die Liebhaberey allgemein weil der Hof das Exempel giebt. Grüssen Sie unsern lieben Müller doch.</div>\n</aside>"
    }
  ],
  "2": []
}
