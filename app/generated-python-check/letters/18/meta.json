  "traditionsHtml": "<section class=\"traditions\" data-letter=\"18\">\n   <div class=\"tradition-app\" data-ref=\"4\">\n      <div class=\"lb-line-block\" data-type=\"break\">\n         \t\t\t\tAugust Stöber: Der Dichter Lenz und Friederike von Sesenheim. Basel 1842, S. 60–62.\n         Stöber spricht davon, dass „einige unvollständige Blättchen bei den Briefen [liegen],\n         welche einzelne philosophische und theologische Betrachtungen, besonders über Leibnitz,\n         enthalten.“ Die Manuskripte der Briefe an Salzmann sind beim Brand der Straßburger\n         Bibliothek 1870 verloren gegangen.\n         \t\t\t</div>\n   </div>\n</section>"
