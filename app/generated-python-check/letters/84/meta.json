  "traditionsHtml": "<section class=\"traditions\" data-letter=\"84\">\n   <div class=\"tradition-app\" data-ref=\"4\">\n      <div class=\"lb-line-block\" data-type=\"break\">\n         \t\t\t\tKraków, Biblioteka Jagiellońska, Lenziana, Sammlung Autographa 1, Nr. 2. Lenz\n         sendet wohl das Exemplar der „Wolken“ an Boie, das zuvor Schlosser hatte und das nun\n         einen Riss aufwies. Die Beilage „von Schlossern“ war wohl gegen Wielands „Abderiten“\n         gerichtet. „Schulmeisterbrief“ ist wohl „Matz Höcker“.  \n         \t\t\t</div>\n   </div>\n</section>"
