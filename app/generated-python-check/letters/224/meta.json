  "traditionsHtml": "<section class=\"traditions\" data-letter=\"224\">\n   <div class=\"tradition-app\" data-ref=\"4\">\n      <div class=\"lb-line-block\" data-type=\"break\">\n         \t\t\t\tRiga, Latvijas Akadēmiskā Bibliotekā, Ms. 1113, F. 25, V. 33, Nr. 6. Roter Siegelrest,\n         Abriss. Zugleich Briefentwurf von Lenz an Seidel „Bitten Sie doch …“; der Umstand,\n         dass die Passage diagonal durchgestrichen wurde, könnte aber auch darauf hinweisen,\n         dass der Brief an Seidel tatsächlich verschickt worden ist.\n         \t\t\t</div>\n   </div>\n</section>"
