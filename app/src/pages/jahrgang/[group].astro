---
import FailurePage from "../../components/FailurePage.astro";
import Layout from "../../layouts/Layout.astro";
import YearGroupPage from "../../components/YearGroupPage.astro";
import {
  getAllYearGroups,
  getGeneratedStatus,
  getYearGroup,
  getYearGroupDefinitions,
  isGeneratedFailureStatus
} from "../../lib/edition";

export async function getStaticPaths() {
  const status = await getGeneratedStatus();
  const groups = isGeneratedFailureStatus(status)
    ? getYearGroupDefinitions()
    : await getAllYearGroups();
  return groups.map((group) => ({ params: { group: group.id } }));
}

const { group: groupId } = Astro.params;
if (!groupId) {
  throw new Error("Missing year group route parameter");
}

const status = await getGeneratedStatus();
const isFailure = isGeneratedFailureStatus(status);
const definitions = getYearGroupDefinitions();
const failureGroup = definitions.find((group) => group.id === groupId) ?? null;

const [groups, group] = isFailure
  ? [definitions, failureGroup]
  : await Promise.all([getAllYearGroups(), getYearGroup(groupId)]);

if (!group) {
  throw new Error(`Unknown year group: ${groupId}`);
}
---

<Layout
  title={isFailure ? "Editionstatus | Lenz-Briefe" : `${group.label} | Lenz-Briefe`}
  description={
    isFailure
      ? `Statusseite fur den Jahrgang ${group.label}.`
      : `Briefe im Zeitraum ${group.label}.`
  }
>
  <div data-pagefind-ignore>
  {isFailure ? <FailurePage status={status} /> : <YearGroupPage groups={groups} group={group} />}
  </div>
</Layout>
