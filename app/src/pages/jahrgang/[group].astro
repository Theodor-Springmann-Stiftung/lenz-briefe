---
import FailureState from "../../components/FailureState.astro";
import Layout from "../../layouts/Layout.astro";
import YearGroupSection from "../../components/YearGroupSection.astro";
import {
  getAllYearGroups,
  getGeneratedStatus,
  getYearGroup,
  getYearGroupDefinitions,
  getYearGroupHref,
  isGeneratedFailureStatus
} from "../../lib/edition";

export async function getStaticPaths() {
  const status = await getGeneratedStatus();
  const groups = isGeneratedFailureStatus(status)
    ? getYearGroupDefinitions()
    : await getAllYearGroups();
  return groups.map((group) => ({ params: { group: group.id } }));
}

const { group: groupId } = Astro.params;
if (!groupId) {
  throw new Error("Missing year group route parameter");
}

const status = await getGeneratedStatus();
const isFailure = isGeneratedFailureStatus(status);
const definitions = getYearGroupDefinitions();
const failureGroup = definitions.find((group) => group.id === groupId) ?? null;

const [groups, group] = isFailure
  ? [definitions, failureGroup]
  : await Promise.all([getAllYearGroups(), getYearGroup(groupId)]);

if (!group) {
  throw new Error(`Unknown year group: ${groupId}`);
}
---

<Layout
  title={`${group?.label ?? groupId} | Lenz-Briefe`}
  description={
    isFailure
      ? `Statusseite fur den Jahrgang ${group?.label ?? groupId}.`
      : `Briefe im Zeitraum ${group?.label ?? groupId}.`
  }
>
  {isFailure ? (
    <FailureState status={status} context="year-group" label={group.label} />
  ) : (
    <>
      <nav class="" aria-label="Briefe nach Jahren">
        {groups.map((item) => (
          <a class="" href={getYearGroupHref(item.id)}>{item.label}</a>
        ))}
      </nav>
      <div class="">
        <YearGroupSection group={group} />
      </div>
    </>
  )}
</Layout>
