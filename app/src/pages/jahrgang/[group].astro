---
import Layout from "../../layouts/Layout.astro";
import YearGroupSection from "../../components/YearGroupSection.astro";
import { getAllYearGroups, getYearGroup, getYearGroupHref } from "../../lib/edition";

export async function getStaticPaths() {
  const groups = await getAllYearGroups();
  return groups.map((group) => ({ params: { group: group.id } }));
}

const { group: groupId } = Astro.params;
if (!groupId) {
  throw new Error("Missing year group route parameter");
}

const [groups, group] = await Promise.all([getAllYearGroups(), getYearGroup(groupId)]);

if (!group) {
  throw new Error(`Unknown year group: ${groupId}`);
}
---

<Layout title={`${group.label} | Lenz-Briefe`} description={`Briefe im Zeitraum ${group.label}.`}>
	<nav class="" aria-label="Briefe nach Jahren">
		{groups.map((group) => (
			<a class="" href={getYearGroupHref(group.id)}>{group.label}</a>
		))}
	</nav>
  <div class="">
    <YearGroupSection group={group} />
  </div>
</Layout>
