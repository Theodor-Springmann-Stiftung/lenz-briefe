---
import FailurePage from "../../components/FailurePage.astro";
import Layout from "../../layouts/Layout.astro";
import LetterPage from "../../components/LetterPage.astro";
import {
  getFailureLetterIds,
  getLetterBundle,
  getLetterIndex,
  getLetterNeighbors,
  getGeneratedStatus,
  isGeneratedFailureStatus
} from "../../lib/edition";

export async function getStaticPaths() {
  const status = await getGeneratedStatus();
  const letters = isGeneratedFailureStatus(status)
    ? getFailureLetterIds().map((letter) => ({ letter }))
    : await getLetterIndex();
  return letters.map((letter) => ({
    params: { letter: letter.letter }
  }));
}

const { letter } = Astro.params;
if (!letter) {
  throw new Error("Missing letter route parameter");
}

const status = await getGeneratedStatus();
const isFailure = isGeneratedFailureStatus(status);
const bundle = isFailure ? null : await getLetterBundle(letter);
const neighbors = isFailure ? null : await getLetterNeighbors(letter);

let year: string | null = null;
let dateText = "";
let personen: string[] = [];
let orte: string[] = [];
if (bundle) {
  const dateStr = bundle.meta.sent.date?.when ?? bundle.meta.received.date?.when ?? "";
  const match = dateStr.match(/^(\d{4})/);
  if (match) {
    year = match[1];
  }
  dateText = bundle.meta.sent.date?.text ?? "";
  personen = [
    ...(bundle.meta.sent.persons ?? []).map((p: { label?: string }) => p.label).filter(Boolean),
    ...(bundle.meta.received.persons ?? []).map((p: { label?: string }) => p.label).filter(Boolean),
  ];
  orte = [
    ...(bundle.meta.sent.locations ?? []).map((l: { label?: string }) => l.label).filter(Boolean),
    ...(bundle.meta.received.locations ?? []).map((l: { label?: string }) => l.label).filter(Boolean),
  ];
}
---

<Layout
  title={isFailure ? "Editionstatus | Lenz-Briefe" : `Brief ${letter} | Lenz-Briefe`}
  description={isFailure ? `Statusseite fur Brief ${letter}.` : bundle?.meta.sent.date?.text ?? `Brief ${letter}`}
>
  {isFailure ? (
    <FailurePage status={status} />
  ) : bundle && neighbors ? (
    <LetterPage bundle={bundle} neighbors={neighbors} />
  ) : null}

  {bundle && (
    <div slot="meta" hidden data-pagefind-filter="bereich:kopf">
      <span data-pagefind-meta="letter">{letter}</span>
      {dateText && <span data-pagefind-meta="date">{dateText}</span>}
      {personen.map((name) => <span data-pagefind-meta="person">{name}</span>)}
      {orte.map((ort) => <span data-pagefind-meta="ort">{ort}</span>)}
    </div>
  )}

  {bundle && (
    <span data-pagefind-filter="year" style="display:none">{year ?? ""}</span>
  )}
</Layout>
