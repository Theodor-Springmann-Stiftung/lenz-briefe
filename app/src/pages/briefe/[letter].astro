---
import FailureState from "../../components/FailureState.astro";
import Layout from "../../layouts/Layout.astro";
import LetterBody from "../../components/LetterBody.astro";
import LetterHeader from "../../components/LetterHeader.astro";
import LetterPageNumbers from "../../components/LetterPageNumbers.astro";
import LetterSidenoteMargins from "../../components/LetterSidenoteMargins.astro";
import LetterTraditions from "../../components/LetterTraditions.astro";
import {
  getFailureLetterIds,
  getLetterBundle,
  getLetterIndex,
  getLetterNeighbors,
  getGeneratedStatus,
  isGeneratedFailureStatus
} from "../../lib/edition";

export async function getStaticPaths() {
  const status = await getGeneratedStatus();
  const letters = isGeneratedFailureStatus(status)
    ? getFailureLetterIds().map((letter) => ({ letter }))
    : await getLetterIndex();
  return letters.map((letter) => ({
    params: { letter: letter.letter }
  }));
}

const { letter } = Astro.params;
if (!letter) {
  throw new Error("Missing letter route parameter");
}

const status = await getGeneratedStatus();
const isFailure = isGeneratedFailureStatus(status);
const bundle = isFailure ? null : await getLetterBundle(letter);
const neighbors = isFailure ? null : await getLetterNeighbors(letter);
---

<Layout
  title={`Brief ${letter} | Lenz-Briefe`}
  description={isFailure ? `Statusseite fur Brief ${letter}.` : bundle?.meta.sent.date?.text ?? `Brief ${letter}`}
>
  {isFailure ? (
    <FailureState status={status} context="letter" label={letter} />
  ) : bundle && neighbors ? (
  <div>
    <LetterHeader meta={bundle.meta} neighbors={neighbors} />

    <section class="grid grid-cols-[4.5rem_minmax(0,1fr)_18rem] items-stretch gap-6 max-[980px]:grid-cols-[3.5rem_minmax(0,1fr)]" data-letter-layout>
      <LetterPageNumbers pages={bundle.pages} />
      <LetterBody textHtml={bundle.textHtml} />
      <LetterSidenoteMargins sidenotesByPage={bundle.sidenotesByPage} />
    </section>

    <LetterTraditions html={bundle.meta.traditionsHtml} />
  </div>
  ) : null}

  <style is:global>
    .letter-body-prose {
      --lb-indent-1: 1.5rem;
      --lb-indent-2: 3rem;
      --lb-indent-3: 4.5rem;
      --lb-indent-4: 6rem;
      --lb-indent-5: 7.5rem;
      --lb-indent-6: 9rem;
      --lb-indent-7: 10.5rem;
      color: #2d2417;
    }

    .letter-body-prose {
      font-family: var(--font-serif);
      font-size: 1.06rem;
      line-height: 1.72;
      color: inherit;
    }

    .letter-body-prose .lb-page {
      display: inline;
      user-select: none;
    }

    .letter-body-prose .lb-line-block,
    .letter-body-prose .lb-tab-row {
      display: block;
    }

    .letter-body-prose .lb-line-block[data-type="break"],
    .letter-body-prose .lb-tab-row[data-type="break"] {
      min-height: 1lh;
    }

    .letter-body-prose .lb-line-block--empty {
      min-height: 1lh;
      margin-block-end: 0.85rem;
    }

    .letter-body-prose .lb-rule {
      width: min(10rem, 35%);
      margin: 1.4rem auto;
      border: 0;
      border-top: 1px solid color-mix(in srgb, currentColor 30%, transparent);
    }

    .letter-body-prose .align {
      display: block;
      width: 100%;
      text-align: start;
    }

    .letter-body-prose .lb-line-block[data-align="center"] {
      text-align: center;
    }

    .letter-body-prose .lb-line-block[data-align="right"] {
      text-align: right;
    }

    .letter-body-prose .align[data-pos="center"] {
      text-align: center;
    }

    .letter-body-prose .align[data-pos="right"] {
      text-align: right;
    }

    .letter-body-prose .lb-line-block[data-tab="1"] {
      text-indent: var(--lb-indent-1);
    }

    .letter-body-prose .lb-tab-row[data-tab="1"] {
      padding-inline-start: var(--lb-indent-1);
    }

    .letter-body-prose .lb-line-block[data-tab="2"] {
      text-indent: var(--lb-indent-2);
    }

    .letter-body-prose .lb-tab-row[data-tab="2"] {
      padding-inline-start: var(--lb-indent-2);
    }

    .letter-body-prose .lb-line-block[data-tab="3"] {
      text-indent: var(--lb-indent-3);
    }

    .letter-body-prose .lb-tab-row[data-tab="3"] {
      padding-inline-start: var(--lb-indent-3);
    }

    .letter-body-prose .lb-line-block[data-tab="4"] {
      text-indent: var(--lb-indent-4);
    }

    .letter-body-prose .lb-tab-row[data-tab="4"] {
      padding-inline-start: var(--lb-indent-4);
    }

    .letter-body-prose .lb-line-block[data-tab="5"] {
      text-indent: var(--lb-indent-5);
    }

    .letter-body-prose .lb-tab-row[data-tab="5"] {
      padding-inline-start: var(--lb-indent-5);
    }

    .letter-body-prose .lb-line-block[data-tab="6"] {
      text-indent: var(--lb-indent-6);
    }

    .letter-body-prose .lb-tab-row[data-tab="6"] {
      padding-inline-start: var(--lb-indent-6);
    }

    .letter-body-prose .lb-line-block[data-tab="7"] {
      text-indent: var(--lb-indent-7);
    }

    .letter-body-prose .lb-tab-row[data-tab="7"] {
      padding-inline-start: var(--lb-indent-7);
    }

    .letter-body-prose .aq {
      font-family: var(--font-sans);
      font-style: normal;
    }

    .letter-body-prose .gr,
    .letter-body-prose .hb,
    .letter-body-prose .ru {
      letter-spacing: 0.04em;
    }

    .letter-body-prose .ul {
      text-decoration: underline;
      text-underline-offset: 0.15em;
    }

    .letter-body-prose .dul {
      text-decoration: underline;
      text-decoration-style: double;
      text-underline-offset: 0.15em;
    }

    .letter-body-prose .tul {
      text-decoration: underline;
      text-decoration-style: wavy;
      text-decoration-thickness: 1.5px;
      text-underline-offset: 0.15em;
    }

    .letter-body-prose .highlight {
      padding-inline: 0.08em;
      border-radius: 0.12em;
      color: inherit;
    }

    .letter-body-prose .undo,
    .letter-body-prose .added {
      text-decoration: underline;
      text-decoration-style: dotted;
      text-underline-offset: 0.15em;
    }

    .letter-body-prose .insertion {
      color: #6e4820;
    }

    .letter-body-prose .insertion[data-pos="top"] {
      vertical-align: super;
      font-size: 0.76em;
      line-height: 1;
    }

    .letter-body-prose del {
      color: color-mix(in srgb, currentColor 78%, transparent);
      text-decoration-thickness: 1px;
    }

    .letter-body-prose .subst {
      white-space: nowrap;
    }

    .letter-body-prose .hand {
      font-family: var(--font-hand);
      font-style: normal;
      color: #1f1c18;
      font-size: 0.95rem;
    }

    .letter-body-prose .note {
      color: #6a6154;
      font-size: 0.94em;
    }

    .letter-body-prose .tl {
      display: inline-block;
      min-width: 0.7em;
      border-bottom: 1px dotted currentColor;
      opacity: 0.55;
      transform: translateY(-0.08em);
    }

    .letter-body-prose .tl::before,
    .letter-body-prose .tl::after,
    .letter-body-prose .nr::before,
    .letter-body-prose .nr::after {
      content: "⸰";
      opacity: 0.85;
    }

    .letter-body-prose .fn,
    .letter-body-prose .anchor {
      vertical-align: super;
      font-size: 0.78em;
      line-height: 1;
    }

    .letter-body-prose .nr {
      color: #7a6a55;
      font-style: italic;
    }

    .letter-body-prose .pe {
      color: #7a5732;
    }

    .letter-body-prose .er {
      opacity: 0.7;
    }

    .letter-body-prose .large {
      font-size: 1.14em;
    }

    .letter-body-prose .sub {
      vertical-align: sub;
      font-size: 0.8em;
    }

    .letter-body-prose .super {
      vertical-align: super;
      font-size: 0.8em;
    }

    .letter-body-prose .sal,
    .letter-body-prose .sig {
      letter-spacing: 0.02em;
    }

    .letter-body-prose .ful {
      display: inline-block;
      min-width: 2rem;
      border-bottom: 1px solid currentColor;
      transform: translateY(-0.12em);
    }

    .letter-body-prose address {
      font-style: inherit;
    }

    .letter-body-prose .tabs {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      margin-block: 1rem;
    }

    .letter-body-prose .lb-tab-row {
      min-width: 0;
    }

    .letter-body-prose .tab {
      min-width: 0;
    }

    .letter-body-prose .tab[data-value="1-2"],
    .letter-body-prose .tab[data-value="2-2"] {
      display: inline-block;
      width: calc(50% - 0.5rem);
      vertical-align: top;
    }

    .letter-body-prose .tab[data-value="1-12"] {
      margin-inline-start: 8.333%;
    }

    .letter-body-prose .tab[data-value="5-12"] {
      margin-inline-start: 41.667%;
    }

    .letter-body-prose .tab[data-value="10-12"] {
      margin-inline-start: 83.333%;
    }

    .letter-body-prose .tab[data-value="1-8"] {
      margin-inline-start: 12.5%;
    }

    .letter-body-prose .tab[data-value="3-8"] {
      margin-inline-start: 37.5%;
    }

    .letter-body-prose .tab[data-value="4-8"] {
      margin-inline-start: 50%;
    }

    .letter-body-prose .tab[data-value="7-8"] {
      margin-inline-start: 87.5%;
    }
  </style>

  <script is:inline>
    (() => {
      const roots = document.querySelectorAll("[data-letter-layout]");

      const isIgnoredNode = (node) => {
        if (node.nodeType === Node.TEXT_NODE) {
          return !node.textContent?.trim();
        }

        if (!(node instanceof HTMLElement)) {
          return false;
        }

        return (
          node.classList.contains("lb-page") ||
          node.classList.contains("page-anchor")
        );
      };

      const buildPageTargets = (body) => {
        const targets = new Map();
        const anchors = Array.from(body.querySelectorAll(".page-anchor"));

        for (const anchor of anchors) {
          if (!(anchor instanceof HTMLElement) || !anchor.id) {
            continue;
          }

          anchor.textContent = anchor.dataset.inlineBreak === "true" ? " | " : "";
          targets.set(anchor.id, anchor);
        }

        return { targets };
      };

      const positionRail = (items, body, rail, pageTargets) => {
        const bodyRect = body.getBoundingClientRect();
        let maxBottom = 0;

        for (const [index, item] of items.entries()) {
          const anchorId = item.getAttribute("data-anchor-id");
          const align = item.getAttribute("data-align") ?? "top";
          if (!anchorId) {
            item.setAttribute("data-positioned", "false");
            continue;
          }

          if (align === "bottom" && index === 0) {
            const label = item.textContent?.trim();
            if (label === "1") {
              item.setAttribute("data-positioned", "false");
              item.style.top = "";
              continue;
            }
          }

          const target =
            align === "bottom"
              ? pageTargets.get(anchorId) ?? null
              : body.querySelector(`#${CSS.escape(anchorId)}`);
          if (!(target instanceof HTMLElement)) {
            item.setAttribute("data-positioned", "false");
            continue;
          }

          const targetRect = target.getBoundingClientRect();
          const rawTop =
            align === "bottom"
              ? targetRect.bottom - bodyRect.top - item.offsetHeight
              : targetRect.top - bodyRect.top;
          const top = Math.max(0, rawTop);
          item.style.top = `${Math.round(top)}px`;
          item.setAttribute("data-positioned", "true");
          maxBottom = Math.max(maxBottom, top + item.offsetHeight);
        }

        rail.style.minHeight = `${Math.max(body.offsetHeight, Math.ceil(maxBottom))}px`;
      };

      const setupLayout = (root) => {
        const body = root.querySelector("[data-letter-body]");
        const pageRail = root.querySelector("[data-page-rail]");

        if (!(body instanceof HTMLElement) || !(pageRail instanceof HTMLElement)) {
          return;
        }

        const pageItems = Array.from(pageRail.querySelectorAll("[data-anchor-id]"));

        const reposition = () => {
          const pageTargets = buildPageTargets(body);
          positionRail(pageItems, body, pageRail, pageTargets.targets);
        };

        const schedule = () => requestAnimationFrame(reposition);
        const resizeObserver = new ResizeObserver(schedule);
        resizeObserver.observe(body);
        resizeObserver.observe(root);

        if (document.fonts?.ready) {
          document.fonts.ready.then(schedule);
        }

        window.addEventListener("resize", schedule, { passive: true });
        schedule();
      };

      for (const root of roots) {
        if (root instanceof HTMLElement) {
          setupLayout(root);
        }
      }
    })();
  </script>
</Layout>
