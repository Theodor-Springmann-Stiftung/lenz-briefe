---
import Layout from "../layouts/Layout.astro";
import YearGroupSection from "../components/YearGroupSection.astro";
import { getYearGroup } from "../lib/edition";

const group = await getYearGroup("1756-1770");

if (!group) {
  throw new Error("Missing first year group");
}
---

<Layout
  title={`${group.label} | Lenz-Briefe`}
  description={`Briefe im Zeitraum ${group.label}.`}
>
  <div class="">
    <header class="">
      <p class="">Jahresgruppe</p>
      <h1 class="">{group.label}</h1>
      <p class="">{group.letters.length} Briefe in dieser Gruppe.</p>
    </header>

    <YearGroupSection group={group} />
  </div>
</Layout>
