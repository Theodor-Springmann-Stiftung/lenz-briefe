---
import FailureState from "../components/FailureState.astro";
import Layout from "../layouts/Layout.astro";
import YearGroupSection from "../components/YearGroupSection.astro";
import {
  getGeneratedStatus,
  getYearGroupHref,
  getAllYearGroups,
  isGeneratedFailureStatus
} from "../lib/edition";

const status = await getGeneratedStatus();
const isFailure = isGeneratedFailureStatus(status);
const groups = isFailure ? [] : await getAllYearGroups();
const group = groups[0] ?? null;
---

<Layout
  title={isFailure ? "Editionstatus | Lenz-Briefe" : `${group?.label ?? "Lenz-Briefe"} | Lenz-Briefe`}
  description={
    isFailure
      ? "Statusseite fur einen fehlgeschlagenen Export der Lenz-Briefe."
      : `Briefe im Zeitraum ${group?.label ?? ""}.`
  }
>
  {isFailure ? (
    <FailureState status={status} context="home" />
  ) : (
    <>
      <nav class="" aria-label="Briefe nach Jahren">
        <ol>
        {groups.map((group) => (
          <li><a class="" href={getYearGroupHref(group.id)}>{group.label}</a></li>
        ))}
        </ol>
      </nav>
      <div class="">
        {group && <YearGroupSection group={group} />}
      </div>
    </>
  )}
</Layout>
