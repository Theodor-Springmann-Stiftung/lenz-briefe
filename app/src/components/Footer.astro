---
import { getGeneratedStatus } from "../lib/edition";

const generatedDate = new Intl.DateTimeFormat("de-DE", {
  month: "long",
  year: "numeric"
}).format(new Date());

const status = await getGeneratedStatus();
const shortHash = status.source.commitHash.substring(0, 7);
---

<footer class="">
  <div class="">
    <div class="">
      <span class="" aria-hidden="true">
        <i class=""></i>
        <i class=""></i>
      </span>
      <span>CC BY 4.0 · {generatedDate} · Commit <a href="/status/">{shortHash}</a></span>
    </div>

    <div class="">
      <span>Ein Projekt der Theodor Springmann Stiftung</span>
      <span aria-hidden="true">·</span>
      <span>Impressum &amp; Datenschutz</span>
      <span aria-hidden="true">·</span>
      <span>Code</span>
    </div>
  </div>
</footer>
