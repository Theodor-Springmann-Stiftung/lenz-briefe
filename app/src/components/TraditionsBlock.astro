---
type Props = {
  html: string | undefined;
};

const { html } = Astro.props;
---

{html && (
  <section class="grid gap-4 border-t border-[var(--rule)] pt-6" aria-labelledby="traditions-heading">
    <div class="grid gap-1">
      <p class="m-0 text-[0.68rem] uppercase tracking-[0.2em] text-[var(--muted)]">Überlieferung</p>
      <h2 class="m-0 text-[1.1rem] font-normal" id="traditions-heading">Tradition</h2>
    </div>
    <div class="prose prose--traditions" set:html={html} />
  </section>
)}
