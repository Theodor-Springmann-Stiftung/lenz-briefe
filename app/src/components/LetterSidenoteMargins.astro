---
import type { SidenotesByPage } from "../lib/edition";

type Props = {
  sidenotesByPage: SidenotesByPage;
};

const { sidenotesByPage } = Astro.props;
const pageGroups = Object.entries(sidenotesByPage).sort((a, b) => Number(a[0]) - Number(b[0]));
---

<div
  class="min-h-full max-[980px]:col-start-2 max-[980px]:mt-6"
  aria-label="Randnotizen"
>
  {pageGroups.flatMap(([page, notes]) =>
    notes.map((note) => (
      <section
        class="mt-4 first:mt-0"
        data-page={page}
      >
        <div set:html={note.html} />
      </section>
    ))
  )}
</div>
